def extract_links_from_text(text, base_url=None, target_domain=None):
    links = set()
    for match in re.findall(r'(?:href|src)=["\']([^"\']+)["\']', text, flags=re.IGNORECASE):
        links.add(match)
    for match in re.findall(r'https?://[^\s\'"<>)]+', text, flags=re.IGNORECASE):
        links.add(match)
    
    if base_url:
        normalized = set()
        for l in links:
            try:
                full = urljoin(base_url, l)
                if full.startswith("http://") or full.startswith("https://"):
                    if target_domain:
                        parsed = urlparse(full)
                        link_domain = parsed.netloc.lower()
                        if target_domain in link_domain or link_domain in target_domain:
                            normalized.add(full)
                    else:
                        normalized.add(full)
            except Exception:
                continue
        return list(normalized)
    
    return [l for l in links if l.startswith("http://") or l.startswith("https://")]


def extract_domains_from_links(links, target_url=None):
    target_domain = None
    if target_url:
        parsed = urlparse(target_url)
        target_domain = parsed.netloc.lower()
        if target_domain.startswith('www.'):
            target_domain = target_domain[4:]
    
    domains = set()
    for link in links:
        try:
            parsed = urlparse(link)
            domain = parsed.netloc.lower()
            if domain:
                clean_domain = domain[4:] if domain.startswith('www.') else domain
                clean_target = target_domain[4:] if target_domain and target_domain.startswith('www.') else target_domain
                
                if not target_domain:
                    domains.add(domain)
                elif clean_domain == clean_target or clean_domain.endswith('.' + clean_target):
                    if domain not in scanned_domains:
                        domains.add(domain)
        except Exception:
            continue
    return list(domains)


