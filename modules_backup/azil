def safe_call(fn, *a, **kw):
    global proxy_session
    try:
        # Pass proxy session to module if it supports it
        if proxy_session and hasattr(fn, 'scan'):
            kw['proxy_session'] = proxy_session
        result = fn(*a, **kw)
        if result and isinstance(result, dict) and 'vulnerabilities' in result:
            return result
        return result
    except Exception as e:
        verbose = kw.get('verbose', False)
        if verbose:
            cprint(f"[MODULE ERROR] {fn.__name__ if hasattr(fn,'__name__') else 'module'}: {e}", "red")
        return None


