def send_request(form, data):
    """Send POST request"""
    headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}
    
    try:
        response = requests.post(
            form['action'],
            data=data,
            headers=headers,
            timeout=10,
            allow_redirects=False
        )
        return response
    except:
        dummy = requests.Response()
        dummy._content = b""
        dummy.status_code = 500
        return dummy


